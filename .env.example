PORT=8787
APP_NAME=Hermes Window

# Optional: echter OpenAI-kompatibler Endpoint
# Zum Beispiel ein Hermes-API-Server oder ein anderer kompatibler Agenten-Endpunkt.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# Optional: wenn dein Endpoint kein /v1 im Base-URL hat, lass dies auf /v1
OPENAI_COMPAT_PREFIX=/v1
